# .env.example — copy to .env and fill in real values before running make setup
# Never commit .env to version control.

# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
POSTGRES_DB=currency_converter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=jdbc:postgresql://db:5432/currency_converter

# ==========================================
# Redis Configuration
# ==========================================
REDIS_URL=redis://redis:6379

# ==========================================
# Spring Boot Application Configuration
# ==========================================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ==========================================
# JWT Security Configuration
# ==========================================
# IMPORTANT: In production, generate a strong random 32+ character secret
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRY_MINUTES=60

# ==========================================
# External Currency API Configuration
# ==========================================
# Get your API key from https://currencyapi.com
CURRENCY_API_KEY=your-currency-api-key-here
CURRENCY_API_BASE_URL=https://api.currencyapi.com

# ==========================================
# Logging Configuration
# ==========================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_FINTECH=DEBUG
LOGGING_LEVEL_SPRING_WEB=INFO
LOGGING_LEVEL_HIBERNATE=WARN

# ==========================================
# Actuator & Monitoring Configuration
# ==========================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus,circuitbreakers,caches
MANAGEMENT_HEALTH_CIRCUITBREAKERS_ENABLED=true

# ==========================================
# Rate Limiting Configuration
# ==========================================
RATE_LIMIT_GLOBAL_REQUESTS_PER_MINUTE=100
RATE_LIMIT_AUTH_REQUESTS_PER_20_SECONDS=5


